# ================================================
# КОНФИГУРАЦИЯ ДЛЯ ЛОКАЛЬНОЙ РАЗРАБОТКИ
# ================================================

# Окружение
NODE_ENV=development
PORT=5000

# Frontend URL - для CORS
FRONTEND_URL=http://localhost:5173

# ================================================
# БАЗА ДАННЫХ (MySQL)
# ================================================
# Для локального использования:
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=clowns_db

# ================================================
# БЕЗОПАСНОСТЬ
# ================================================
# JWT Secret для подписи токенов (ИЗМЕНИТЕ В PRODUCTION!)
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_EXPIRE=7d

# ================================================
# ПРИМЕЧАНИЯ ДЛЯ ЛОКАЛЬНОЙ РАЗРАБОТКИ
# ================================================
# 1. Убедитесь, что MySQL запущен: 
#    - WampServer / Xampp / MySQLServer должны быть включены
#
# 2. Запустить БД:
#    mysql -u root -p < database.sql
#
# 3. Запустить backend:
#    npm run dev
#
# 4. Frontend будет подключаться к http://localhost:5000
